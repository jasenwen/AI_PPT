# === LiteLLM Configuration ===
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_API_KEY=sk-xxx
LITELLM_MODEL=claude-sonnet-4-20250514

# SVG generation model (optional, defaults to LITELLM_MODEL)
LITELLM_SVG_MODEL=
LITELLM_SVG_TEMPERATURE=0

# MarkItDown OCR model (optional, defaults to LITELLM_MODEL)
LITELLM_OCR_MODEL=gpt-4o

# === MongoDB (reuse LibreChat instance) ===
MONGO_URI=mongodb://localhost:27017/LibreChat

# === PPT Engine ===
PPT_ENGINE_HOST=0.0.0.0
PPT_ENGINE_PORT=8100
PPT_PROJECTS_DIR=./data/projects
PPT_TEMPLATES_DIR=./data/templates
